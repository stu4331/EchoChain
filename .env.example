# Erryn's Soul Environment Variables
# Copy this to .env and fill in your actual API keys
# NEVER commit .env to GitHub!

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here-at-least-40-chars
OPENAI_MODEL=gpt-4o-mini

# Azure Speech (Text-to-Speech) Configuration
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=australiaeast

# Optional: Encrypted Journal Password
# If not set, uses a default - highly recommended you set this!
JOURNAL_PASSWORD=change_me_to_something_strong_and_secure
